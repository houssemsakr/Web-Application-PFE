@model Web_Application_PFE.ViewModels.VersionViewModel

@{
    ViewData["Title"] = $"Détails Version V{Model.VersionNumber}";
    Layout = "~/Views/Shared/_Layout-2.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Edit.css" />
}

<div class="custom-form px-4 py-8">
    <div class="form-sections-container">
        <!-- Section Client -->
        <div class="form-section mb-8 p-6 border border-border rounded-md shadow-sm">
            <div class="inline-block px-3 py-1 mb-6 text-sm font-medium bg-muted rounded-md">
                Client
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-6">
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">ID Client</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @Model.ClientId
                    </div>
                </div>
               
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">Commercial</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @Model.Sales
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">Client</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @Model.Customer
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">RFQ ID</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        RFQ-@Model.RFQId
                    </div>
                </div>
            </div>
        </div>

        <!-- Section RFQ -->
        <div class="form-section mb-8 p-6 border border-border rounded-md shadow-sm">
            <div class="inline-block px-3 py-1 mb-6 text-sm font-medium bg-muted rounded-md">
                RFQ
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-6">
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">Nom du Devis</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @Model.QuoteName
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">Segment Marché</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @Model.MarketSegment
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">Références à coter</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @Model.NumberOfRefToBeQuoted
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">Date SOP</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @(Model.SOPDate.ToString("dd/MM/yyyy") ?? "N/A")
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">Volume Max</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @Model.MaxVolume
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">Volume Estimé</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @Model.EstimatedVolume
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sections Matériels, Teste et VA -->
    <div class="form-sections-container">
        <!-- Section Matériels -->
        <div class="form-section mb-8 p-6 border border-border rounded-md shadow-sm">
            <div class="inline-block px-3 py-1 mb-6 text-sm font-medium bg-muted rounded-md">
                Matériels
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-6">
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">Date KO</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @(Model.KOdate.ToString("dd/MM/yyyy") ?? "N/A")
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">Date Données Client</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @(Model.CustomerDatadate.ToString("dd/MM/yyyy") ?? "N/A")
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">Leader Matériels</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @Model.MaterialLeader
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">Date Due Matériels</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @(Model.MaterialDueDate.ToString("dd/MM/yyyy") ?? "N/A")
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">Date Release Matériels</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @(Model.MaterialRelease.ToString("dd/MM/yyyy") ?? "N/A")
                    </div>
                </div>
            </div>
        </div>

        <!-- Section Teste -->
        <div class="form-section mb-8 p-6 border border-border rounded-md shadow-sm">
            <div class="inline-block px-3 py-1 mb-6 text-sm font-medium bg-muted rounded-md">
                Teste
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-6">
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">Leader Test</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @Model.TestLeader
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">Date Due Test</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @(Model.TestDueDate.ToString("dd/MM/yyyy") ?? "N/A")
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">Date Release Test</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @(Model.TestRelease.ToString("dd/MM/yyyy") ?? "N/A")
                    </div>
                </div>
            </div>
        </div>

        <!-- Section VA -->
        <div class="form-section mb-8 p-6 border border-border rounded-md shadow-sm">
            <div class="inline-block px-3 py-1 mb-6 text-sm font-medium bg-muted rounded-md">
                VA
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-6">
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">Leader VA</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @Model.VALeader
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">Date Due Labour</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @(Model.LabourDueDate.ToString("dd/MM/yyyy") ?? "N/A")
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">Date Release Labour</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @(Model.LabourRelease.ToString("dd/MM/yyyy") ?? "N/A")
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">Date Due Client</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @(Model.CustomerDueDate.ToString("dd/MM/yyyy") ?? "N/A")
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">Statut Travail</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @Model.WorkingStatus
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">Date Approbation</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @(Model.ApprovalDate.ToString("dd/MM/yyyy") ?? "N/A")
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Section Matériels (Feasibility, DFM, DFT) -->
    <div class="form-sections-container">
        <div class="form-section mb-8 p-6 border border-border rounded-md shadow-sm">
            <div class="inline-block px-3 py-1 mb-6 text-sm font-medium bg-muted rounded-md">
                Matériels
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-6">
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">Évaluation Faisabilité</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @Model.Feasibilityassessment
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">DFM</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @Model.DFM
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">DFT</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @Model.DFT
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">Revenue Max</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @Model.MaxRevenue
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">Revenue Estimé</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @Model.EstimatedRevenue
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">NRE</label>
                    <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                        @Model.NRE
                    </div>
                </div>
            </div>
        </div>

        <!-- Section Feedback -->
        <div class="form-section mb-8 p-6 border border-border rounded-md shadow-sm">
            <div class="inline-block px-3 py-1 mb-6 text-sm font-medium bg-muted rounded-md">
                Feedback
            </div>
            <div class="grid grid-cols-2 gap-6">
                <div style="margin-right:114px;margin-top:-19px">
                    <div class="rfq-meta">
                        <div class="rfq-status-select" style="margin-bottom:34px;">
                            <label class="block text-sm font-medium text-gray-700">Statut</label>
                            <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                                @Model.Statut
                            </div>
                        </div>
                    </div>
                    <div class="rfq-date">
                        <label class="block text-sm font-medium text-gray-700">Date Feedback</label>
                        <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                            @(Model.FeedbackDate?.ToString("dd/MM/yyyy") ?? "N/A")
                        </div>
                    </div>
                </div>
                <div>
                    <div style="margin-right:170px;margin-left:-270px;margin-top:-30px;">
                        <div class="space-y-2">
                            <label class="block text-sm font-medium text-gray-700">Commentaires</label>
                            <div style="width: 130%; max-width: 950px; height: 120px; font-size: 20px; padding: 6px 12px; border: 1px solid black;">
                                @Model.Comments
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

   
        <!-- Section Statut -->
        <div class="form-sections-container">
            <div class="form-section mb-8 p-6 border border-border rounded-md shadow-sm">
                <div class="inline-block px-3 py-1 mb-6 text-sm font-medium bg-muted rounded-md">
                    Statut
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-6">
                    <div class="rfq-meta">
                        <div class="rfq-status-select" style="margin-bottom:34px;">
                            <label class="block text-sm font-medium text-gray-700">Statut RFQ</label>
                        <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                                @Model.StatutRFQ
                            </div>
                        </div>
                    </div>
                    <div class="rfq-meta">
                        <div class="rfq-status-select" style="margin-bottom:34px;">
                            <label class="block text-sm font-medium text-gray-700">Temps RFQ</label>
                        <div style="width: 55%; max-width: 200px; height: 45%; padding: 6px 12px; border: 1px solid black;">
                                @Model.TimeRFQ
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    

    <!-- Boutons d'action -->
    <div class="flex space-x-6 justify-end mt-6">
        <div class="flex space-x-6 justify-end">
            <a href="@Url.Action("Affiche_Versions")" class="action-btn2 bg-red text-white hover:bg-navy-light">
                <i class="bi bi-arrow-left-short fs-3"></i>
                <span style="margin: 0 auto;">Retour</span>
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            if (feather) {
                feather.replace();
            }
            if (lucide) {
                lucide.createIcons();
            }
        });
    </script>
}