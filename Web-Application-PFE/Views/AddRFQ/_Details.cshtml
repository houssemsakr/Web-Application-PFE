@model Web_Application_PFE.ViewModels.AddRFQViewModel
@Html.AntiForgeryToken()



<!-- Right Column - Content -->
<div class="content-card">
    <div class="document-table-header">
        <div class="document-header-container">
            <!-- Titre du RFQ (à gauche) -->
            <div class="document-name-header">
                <div class="document-card-content">
                    <div class="document-actions">
                        <button class="action-button" onclick="location.href='@Url.Action("Edit", new { id = Model.Id })'">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pencil-square" viewBox="0 0 16 16">
                                <path d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z" />
                                <path fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5z" />
                            </svg>
                            <span class="action-tooltip">Edit Document</span>
                        </button>
                       
                        <button class="action-button" onclick="loadDetails('@Url.Action("Details", "AddRFQ", new { id = Model.Id })')">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path>
                                <circle cx="12" cy="12" r="3"></circle>
                            </svg>
                            <i class="bi bi-eye" style="font-size: 1.2rem; font-weight: bold;"></i>
                            <span class="action-tooltip">View</span>
                        </button>
                        @if (User.IsInRole("Validateur"))
                        {
                        <button class="action-button" onclick="confirmDelete(@Model.Id)">
                           
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash3-fill" viewBox="0 0 16 16">
                                <path d="M11 1.5v1h3.5a.5.5 0 0 1 0 1h-.538l-.853 10.66A2 2 0 0 1 11.115 16h-6.23a2 2 0 0 1-1.994-1.84L2.038 3.5H1.5a.5.5 0 0 1 0-1H5v-1A1.5 1.5 0 0 1 6.5 0h3A1.5 1.5 0 0 1 11 1.5m-5 0v1h4v-1a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 0-.5.5M4.5 5.029l.5 8.5a.5.5 0 1 0 .998-.06l-.5-8.5a.5.5 0 1 0-.998.06m6.53-.528a.5.5 0 0 0-.528.47l-.5 8.5a.5.5 0 0 0 .998.058l.5-8.5a.5.5 0 0 0-.47-.528M8 4.5a.5.5 0 0 0-.5.5v8.5a.5.5 0 0 0 1 0V5a.5.5 0 0 0-.5-.5" />
                            </svg>
                                <i class="bi bi-trash3-fill" style="font-size: 1.2rem; font-weight: bold;"> </i>
                            <span class="action-tooltip">Delete</span>
                        </button>
                        }
                    </div>
                </div>
            </div>

            <!-- Détails du RFQ (au centre) -->
            <div class="document-card-header">
                <div class="document-header-content">
                    <div class="document-icon-wrapper">
                        <img src="/images/RFQ.png" alt="Logo" class="w-8 h-11">
                    </div>
                    <div>
                        <div class="document-title">
                            <span class="document-number">RFQ N°0  @Html.DisplayFor(model => model.RFQId)</span>
                        </div>
                        <div class="document-description">Format RFQ</div>
                    </div>
                </div>
            </div>

            <!-- Date de création (à droite) -->
            <div class="document-date"> @Html.DisplayFor(model => model.DateCreation)</div>
        </div>
    </div>


    <div class="status-indicator" style="  margin-top: 1rem;"> <h4> @Html.DisplayFor(model => model.Statut)</h4></div>
    <br />

    <div class="flex flex-col gap-3 transform -translate-y-4">

        <!-- Client Section -->
        <div class="form-section-container p-6 border-2 border-gray-300 rounded-md shadow-sm">
            <div class="inline-block px-3 py-1 mb-1 mt-1 text-sm font-medium bg-muted rounded-md">
                Client
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-1">

                <div class="space-y-2">
                    <label for="sales" class="block text-sm font-medium text-gray-700">Sales</label>

                    <input id="sales"
                           name="sales"
                           value=" @Html.DisplayFor(model => model.Sales)"
                           style="width: 90%; max-width: 250px;height:45%"
                           class="input" readonly />

                </div>
                <div class="space-y-2">
                    <label for="customer" class="block text-sm font-medium text-gray-700">Customer</label>

                    <input id="customer"
                           name="customer"
                           value=" @Html.DisplayFor(model => model.Customer)"
                           style="width: 90%; max-width: 250px;height:45%"
                           class="input" readonly />

                </div>
                <div class="space-y-2">
                    <label for="cqNumber" class="block text-sm font-medium text-gray-700">CQ #</label>

                    <input id="cqNumber"
                           name="cqNumber"
                           value=" @Html.DisplayFor(model => model.ClientId)"
                           style="width: 90%; max-width: 250px;height:45%"
                           class="input" readonly />

                </div>
            </div>
        </div>

        <!-- RFQ Section -->
        <div class="form-section-container p-6 border-2 border-gray-300 rounded-md shadow-sm">

            <div class="inline-block px-3 py-1 mb-1 text-sm font-medium bg-muted rounded-md">

                RFQ
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-3">

                <div class="space-y-2">
                    <label for="quoteName" class="field-label">Quote Name</label>
                    <input id="quoteName"
                           name="quoteName"
                           value=" @Html.DisplayFor(model => model.QuoteName)"
                           style="width: 90%; max-width: 250px;height:45%"
                           class="input" readonly />

                </div>
                <div class="space-y-2">
                    <label for="marketSegment" class="block text-sm font-medium text-gray-700">Market Segment</label>

                    <input id="marketSegment"
                           name="marketSegment"
                           value=" @Html.DisplayFor(model => model.MarketSegment)"
                           style="width: 90%; max-width: 250px;height:45%"
                           class="input" readonly />

                </div>
                <div class="space-y-2">
                    <label for="refNumber" class="block text-sm font-medium text-gray-700">Number of Ref to be quoted</label>

                    <input id="refNumber"
                           name="refNumber"
                           value=" @Html.DisplayFor(model => model.NumberOfRefToBeQuoted)"
                           style="width: 90%; max-width: 250px;height:45%"
                           class="input" readonly />


                </div>
                <div class="space-y-2">
                    <label for="sopDate" class="block text-sm font-medium text-gray-700">SOP Date</label>


                    <input id="sopDate"
                           name="sopDate"
                           value=" @Html.DisplayFor(model => model.SOPDate)"
                           style="width: 90%; max-width: 250px;height:45%"
                           class="w-full input" readonly />

                </div>
                <div class="space-y-2">
                    <label for="maxVolume" class="block text-sm font-medium text-gray-700">Max Volume</label>

                    <input id="maxVolume"
                           name="maxVolume"
                           value=" @Html.DisplayFor(model => model.MaxVolume)"
                           style="width: 90%; max-width: 250px;height:45%"
                           class="w-full input" readonly />

                </div>
                <div class="space-y-2">
                    <label for="estimatedVolume" class="block text-sm font-medium text-gray-700">Estimated Volume</label>

                    <input id="estimatedVolume"
                           name="estimatedVolume"
                           value=" @Html.DisplayFor(model => model.EstimatedVolume)"
                           style="width: 90%; max-width: 250px;height:45%"
                           class="w-full input" readonly />
                </div>
            </div>
        </div>
        </>
    </div>
</div>
