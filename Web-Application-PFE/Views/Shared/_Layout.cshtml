@inject Web_Application_PFE.Services.Interfaces.IDashboardService DashboardService
@using Microsoft.AspNetCore.Identity
@using Web_Application_PFE.Models
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager

   

    @{
    ViewData["Title"] = "_Layout";

    // Initialiser avec des valeurs par défaut
    var nom = "Utilisateur inconnu";
    var prenom = "Non défini";
    var photoPath = "/images/person.jpg";
    var role = "Aucun rôle";
    var isAdmin = false;
    var isValidateur = false;

    // Récupérer l'utilisateur seulement si connecté
    if (SignInManager.IsSignedIn(User))
    {
        var user = await UserManager.GetUserAsync(User);
        if (user != null)
        {
            nom = user.Nom ?? nom;
            prenom = user.Prenom ?? prenom;
            photoPath = string.IsNullOrEmpty(user.imagePath) ? 
                photoPath : 
                user.imagePath.StartsWith("/") ? user.imagePath : $"/images/{user.imagePath}";

            var roles = await UserManager.GetRolesAsync(user);
            role = roles.FirstOrDefault() ?? role;
            isAdmin = await UserManager.IsInRoleAsync(user, "Admin");
            isValidateur = await UserManager.IsInRoleAsync(user, "Validateur");
        }
    }
}
@{
    var dashboardStats = DashboardService.GetDashboardStats();
}
