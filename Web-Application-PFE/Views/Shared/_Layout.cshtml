    <script src="https://unpkg.com/feather-icons"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- Ajouter les nouveaux scripts JavaScript -->
    <script src="//netdna.bootstrapcdn.com/twitter-bootstrap/2.3.2/js/bootstrap.min.js"></script>
    <script src="//code.jquery.com/jquery-1.11.1.min.js"></script>
    <script src="~/js/site.js" defer></script>

    @await RenderSectionAsync("Scripts", required: false)
    <script>
        // Gestion du menu profil
         document.getElementById('profile-menu').addEventListener('click', function() {
             document.getElementById('dropdown-menu').classList.toggle('hidden');
         });
    </script>
    <script>
        // Solution basée sur Razor qui fonctionne toujours
        (function() {
        @{
            var controller = ViewContext.RouteData.Values["Controller"]?.ToString();
            var action = ViewContext.RouteData.Values["Action"]?.ToString();
            var title = "Tableau de bord";

            if (controller == "Home" && action == "Index")
                title = "Tableau de bord";
            else if (controller == "AddRFQ" && action == "Create")
                title = "Créer nouvelle RFQ";
            else if (controller == "AddRFQ" && action == "Gestion_RFQ")
                title = "Gestion RFQ";
            // Ajouter d'autres cas au besoin
        }

            const titleElement = document.getElementById('page-title');
            if (titleElement) {
                titleElement.textContent = '@title';
            }
        })();
    </script>
    <script>
        // Gestion du menu profil
        document.getElementById('profile-menu').addEventListener('click', function(e) {
            e.stopPropagation(); // Empêche la propagation pour ne pas déclencher le document.click immédiatement
            document.getElementById('dropdown-menu').classList.toggle('hidden');
        });

        // Fermer le menu quand on clique ailleurs
        document.addEventListener('click', function(e) {
            const dropdownMenu = document.getElementById('dropdown-menu');
            const profileMenu = document.getElementById('profile-menu');

            if (!profileMenu.contains(e.target) && !dropdownMenu.contains(e.target)) {
                dropdownMenu.classList.add('hidden');
            }
        });
                document.getElementById('profile-menu').onclick = function(e) {
            e.stopPropagation();
            document.getElementById('dropdown-menu').classList.toggle('hidden');
        };

        document.onclick = function() {
            document.getElementById('dropdown-menu').classList.add('hidden');
        };
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const notificationBtn = document.getElementById('notification-btn');
            const notificationDropdown = document.getElementById('notification-dropdown');
            const notificationList = document.getElementById('notification-list');
            const notificationBadge = document.getElementById('notification-badge');

            // Charger les notifications au clic
            notificationBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                loadNotifications();
                notificationDropdown.classList.toggle('hidden');
            });

            // Fermer le dropdown quand on clique ailleurs
            document.addEventListener('click', function() {
                notificationDropdown.classList.add('hidden');
            });

            // Empêcher la fermeture quand on clique dans le dropdown
            notificationDropdown.addEventListener('click', function(e) {
                e.stopPropagation();
            });

            // Fonction pour charger les notifications
            function loadNotifications() {
                fetch('/AddRFQ/GetNotifications')
                    .then(response => response.json())
                    .then(data => {
                        updateNotificationList(data);
                        updateNotificationBadge(data);
                    })
                    .catch(error => {
                        console.error('Error loading notifications:', error);
                        notificationList.innerHTML = `
                            <div class="p-4 text-center text-red-500">
                                Erreur lors du chargement des notifications
                            </div>
                        `;
                    });
            }

            // Mettre à jour la liste des notifications
                   // Mettre à jour la liste des notifications
        function updateNotificationList(notifications) {
            if (notifications.length === 0) {
                notificationList.innerHTML = `
                    <div class="p-4 text-center text-gray-500">
                        Aucune notification disponible
                    </div>
                `;
                return;
            }

            notificationList.innerHTML = notifications.map(notification => {
                let message = '';

                if (notification.status === "En attente de Validation") {
                    message = `
                        <span class="font-semibold text-blue-600">${notification.userRole}</span>
                        <span class="font-semibold">${notification.userName}</span> a créé une nouvelle RFQ
                        <span class="font-bold text-indigo-700">N°${notification.rfqnumber}</span>
                    `;
                } else if (notification.status === "Validée") {
                    message = `
                        <span class="font-semibold text-green-600">Validateur</span>
                        <span class="font-semibold">${notification.userName}</span> a validé la RFQ
                        <span class="font-bold text-indigo-700">N°${notification.rfqnumber}</span>
                    `;
                } else if (notification.status === "Non Validée") {
                    message = `
                        <span class="font-semibold text-red-600">Validateur</span>
                        <span class="font-semibold">${notification.userName}</span> a rejeté la RFQ
                        <span class="font-bold text-indigo-700">N°${notification.rfqnumber}</span>
                    `;
                }

                return `
                    <div class="p-3 border-b hover:bg-gray-50 cursor-pointer ${notification.isRead ? '' : 'bg-blue-50'}"
                         onclick="markAsRead(${notification.id}, this)">
                        <div class="flex justify-between items-start">
                            <div class="flex-1">
                                <p class="text-sm font-medium text-gray-800">
                                    ${message}
                                </p>
                            </div>
                            <br />
                            <span class="text-xs text-gray-400">${formatDate(notification.creationDate)}</span>
                        </div>
                        ${notification.comment ? `<p class="text-xs mt-1 text-gray-600">Commentaire: ${notification.comment}</p>` : ''}
                    </div>
                `;
            }).join('');
        }

            // Mettre à jour le badge de notification
            function updateNotificationBadge(notifications) {
                const unreadCount = notifications.filter(n => !n.isRead).length;
                if (unreadCount > 0) {
                    notificationBadge.textContent = unreadCount;
                    notificationBadge.classList.remove('hidden');
                } else {
                    notificationBadge.classList.add('hidden');
                }
            }

            // Formater la date
            function formatDate(dateString) {
                const date = new Date(dateString);
                return date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) + ' ' +
                       date.toLocaleDateString([], { day: '2-digit', month: '2-digit' });
            }

            // Marquer une notification comme lue
            window.markAsRead = function(id, element) {
                fetch('/AddRFQ/MarkNotificationAsRead?id=' + id, {
                    method: 'POST'
                })
                .then(response => {
                    if (response.ok) {
                        element.classList.remove('bg-blue-50');
                        // Mettre à jour le compteur
                        const currentCount = parseInt(notificationBadge.textContent);
                        if (currentCount > 1) {
                            notificationBadge.textContent = currentCount - 1;
                        } else {
                            notificationBadge.classList.add('hidden');
                        }
                    }
                })
                .catch(error => console.error('Error marking as read:', error));
            };

            // Charger les notifications au chargement de la page
            loadNotifications();

            // Actualiser les notifications toutes les 30 secondes
            setInterval(loadNotifications, 30000);
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</body>
</html>